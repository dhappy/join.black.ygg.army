# Public, build-time configuration ONLY. No private keys, no secret API keys here.
# All keys are exposed to the static client bundle.

# ── Multi-chain config (preferred) ────────────────────────────────────────────
# PUBLIC_CHAINS is a JSON array of the deployments the UI can target; the in-app chain selector
# switches between them. PUBLIC_DEFAULT_CHAIN_ID picks the default (Ethereum mainnet, 1, if
# unset). gasPolicyId is the per-chain Alchemy Gas Manager policy; rpcUrl should be an Alchemy RPC.
PUBLIC_DEFAULT_CHAIN_ID=1
PUBLIC_CHAINS=[{"chainId":11155111,"label":"Ethereum Sepolia","rpcUrl":"https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY","registrarAddress":"0x7b18109A099b30D116aDE0F0fc7DFAA05FFBa115","registrarName":"BlackYggdrasilRegistrar","registrarVersion":"1","postfix":"black.ygg.army","explorerUrl":"https://sepolia.etherscan.io","gasPolicyId":"sepolia-policy-id"},{"chainId":1,"label":"Ethereum","rpcUrl":"https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY","registrarAddress":"0x7b18109A099b30D116aDE0F0fc7DFAA05FFBa115","registrarName":"BlackYggdrasilRegistrar","registrarVersion":"1","postfix":"black.ygg.army","explorerUrl":"https://etherscan.io","gasPolicyId":"mainnet-policy-id"}]

# The Alchemy app API key is shared across chains (the Gas Manager policy is per-chain, above). Both
# the key and a chain's gasPolicyId are required for the gasless claim submission (reads / the admin
# UI work without them). It ships in the static bundle, so domain-allowlist it in the dashboard and
# scope each gas policy (sender/contract + spend caps). See src/lib/aa/account.ts.
PUBLIC_ALCHEMY_API_KEY=

# ── Legacy single-chain config (fallback) ─────────────────────────────────────
# If PUBLIC_CHAINS is unset, the app builds a single target from these flat keys (kept so dev/CI/test
# envs keep working). Set EITHER the block above OR these, not both.
# PUBLIC_CHAIN_ID=
# PUBLIC_RPC_URL=
# PUBLIC_REGISTRAR_ADDRESS=
# PUBLIC_POSTFIX=black.ygg.army
# PUBLIC_REGISTRAR_NAME=
# PUBLIC_REGISTRAR_VERSION=1
# PUBLIC_EXPLORER_URL=https://sepolia.etherscan.io
# PUBLIC_GAS_POLICY_ID=
