PUBLIC_RPC_URL=
PUBLIC_REGISTRAR_ADDRESS=
PUBLIC_POSTFIX=black.ygg.army
PUBLIC_REGISTRAR_NAME=
PUBLIC_REGISTRAR_VERSION=1

