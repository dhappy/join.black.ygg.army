# Public, build-time configuration ONLY. No private keys, no secret API keys here.
# All keys are exposed to the static client bundle.

PUBLIC_CHAIN_ID=
PUBLIC_RPC_URL=
PUBLIC_REGISTRAR_ADDRESS=
PUBLIC_POSTFIX=black.ygg.army
PUBLIC_REGISTRAR_NAME=
PUBLIC_REGISTRAR_VERSION=1

# Optional: override the success-screen block-explorer base URL. Known chains (incl. Base Sepolia,
# 84532) are auto-detected, so leave this unset unless your chain isn't recognized.
# PUBLIC_EXPLORER_URL=https://sepolia.basescan.org

# Gas sponsorship uses Biconomy MEE testnet sponsorship (out-of-the-box, no bundler/Paymaster URLs
# or dashboard). See src/lib/aa/account.ts and https://docs.biconomy.io/gasless-apps/testnet-sponsorship
